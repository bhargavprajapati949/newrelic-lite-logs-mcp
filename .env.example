# Primary auth mode. Keep api_key_only for default runtime.
NEW_RELIC_DEFAULT_AUTH_MODE=api_key_only

# Required in api_key_only mode.
NEW_RELIC_API_KEY=YOUR_NEW_RELIC_USER_API_KEY

# Required only when NEW_RELIC_DEFAULT_AUTH_MODE=cookie or for emergency fallback testing.
NEW_RELIC_COOKIE=

# Default account id used when tool call does not provide accountId.
NEW_RELIC_ACCOUNT_ID=1867676

# Optional: set to 1 for verbose debug logs.
NEW_RELIC_VERBOSE_LOGS=0
